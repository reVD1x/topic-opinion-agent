# ── PostgreSQL（应用层使用 PG_ 前缀）──────────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=your_user
PG_PASSWORD=your_password
PG_DB=your_db

# ── PostgreSQL（MindSpider 爬虫使用 DB_ 前缀）───────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_db
DB_DIALECT=postgresql
DB_CHARSET=utf8mb4

# ── 日志级别 ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── MindSpider 库表 ────────────────────────────────────────────────────
TABLE_DAILY_TOPICS=daily_topics
TABLE_DAILY_NEWS=daily_news
TABLE_TOPIC_NEWS_RELATION=topic_news_relation
TABLE_CRAWLING_TASKS=crawling_tasks
TABLE_PLATFORM_CONTENT=platform_content
TABLE_PLATFORM_LIST=xhs_note,douyin_aweme,kuaishou_video,bilibili_video,weibo_note,tieba_note,zhihu_content

# ── 话题匹配列名 ───────────────────────────────────────────────────────
TOPIC_ID_COLUMN=topic_id
TOPIC_NAME_COLUMN=topic_name
TOPIC_DATE_COLUMN=topic_date

# ── 外部检索 ──────────────────────────────────────────────────────────
BOCHA_ENABLED=true
BOCHA_API_KEY=
BOCHA_BASE_URL=https://api.bocha.cn/v1/ai-search
TAVILY_ENABLED=true
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com/search

# ── LLM 网关（OpenAI 兼容接口）─────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=1.0
LLM_RETRY_MAX_SECONDS=8.0
LLM_JSON_MODE=true
LLM_TEMPERATURE=-1
LLM_THINKING_DISABLED=true

# ── MindSpider 爬虫 ────────────────────────────────────────────────────
MINDSPIDER_ENABLED=true
MINDSPIDER_MODULE_PATH=MindSpider
MINDSPIDER_API_KEY=
MINDSPIDER_BASE_URL=https://api.deepseek.com
MINDSPIDER_MODEL_NAME=deepseek-v4-flash
MINDSPIDER_CRAWLER_LOOP=true
MINDSPIDER_RUN_ON_START=false
MINDSPIDER_CRAWLER_INTERVAL_SECONDS=86400
MINDSPIDER_KEYWORDS_COUNT=100
MINDSPIDER_MAX_KEYWORDS=50
MINDSPIDER_MAX_NOTES=50
MINDSPIDER_TEST_MODE=false
MINDSPIDER_PLATFORMS=xhs,dy,wb,zhihu
